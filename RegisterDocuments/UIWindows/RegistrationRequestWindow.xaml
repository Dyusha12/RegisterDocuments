<Window x:Class="RegisterDocuments.RegistrationRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Получение доступа"
        Height="700"
        Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#E6F0FA">
    
    <!-- Ресурсы окна -->
    <Window.Resources>

        <!-- Основные цвета -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#4A90E2"/>
        <SolidColorBrush x:Key="LightBlue" Color="#DCEEFF"/>
        <SolidColorBrush x:Key="DarkGray" Color="#333333"/>
        <SolidColorBrush x:Key="LightGray" Color="#777777"/>
        <SolidColorBrush x:Key="HoverBlue" Color="#357ABD"/>
        <SolidColorBrush x:Key="PressedBlue" Color="#2C5F9E"/>

        <!-- Стиль кнопок -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#357ABD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2C5F9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопк показа/скрытие пароля -->
        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>

            <!-- Кастомный шаблон TextBox -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                 Background="{TemplateBinding Background}"
                 BorderBrush="{TemplateBinding BorderBrush}"
                 BorderThickness="{TemplateBinding BorderThickness}"
                 CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4A90E2"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#357ABD"/>
                                <Setter TargetName="border" Property="Background" Value="#EAF3FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для PasswordBox -->
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <!-- Кастомный шаблон PasswordBox -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                 Background="{TemplateBinding Background}"
                 BorderBrush="{TemplateBinding BorderBrush}"
                 BorderThickness="{TemplateBinding BorderThickness}"
                 CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#4A90E2"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#357ABD"/>
                                <Setter TargetName="border" Property="Background" Value="#EAF3FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Основная сетка -->
    <Grid>

        <!-- Карточка формы -->
        <Border Width="320"
                Background="White"
                CornerRadius="12"
                Padding="25"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15"
                                  ShadowDepth="3"
                                  Opacity="0.3"/>
            </Border.Effect>

            <StackPanel>

                <TextBlock Text="Получение доступа"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Поля ввода -->
                <TextBlock Text="Логин"
                           Foreground="{StaticResource LightGray}"
                           Margin="0,0,0,2" FontSize="18"/>
                <TextBox x:Name="LoginBox" FontSize="14"/>

                <TextBlock Text="Фамилия"
                       Foreground="{StaticResource LightGray}"
                       Margin="0,0,0,2" FontSize="18"/>
                <TextBox x:Name="LastNameBox" FontSize="14"/>

                <TextBlock Text="Имя"
                       Foreground="{StaticResource LightGray}"
                       Margin="0,0,0,2" FontSize="18"/>
                <TextBox x:Name="FirstNameBox" FontSize="14"/>

                <TextBlock Text="Отчество"
                     Foreground="{StaticResource LightGray}"
                     Margin="0,0,0,2" FontSize="18"/>
                <TextBox x:Name="MiddleNameBox" FontSize="14"/>

                <TextBlock Text="Пароль"
                           Foreground="{StaticResource LightGray}"
                           Margin="0,0,0,2" FontSize="18"/>

                <!-- Пароль -->
                <Grid>
                    <PasswordBox x:Name="PasswordBox"
                             FontSize="14"
                             Padding="8,4"
                             PasswordChanged="PasswordBox_PasswordChanged"/>
                    <TextBox x:Name="PasswordTextBox"
                             FontSize="14"
                             Padding="8,4"
                             Visibility="Collapsed"/>
                    <Button
                             Style="{StaticResource EyeButtonStyle}"
                             HorizontalAlignment="Right"
                             Margin="0,-10,5,0"
                             Click="TogglePassword_Click">
                        <Image Source="pack://application:,,,/Images/ic_showPassword.png"
                               Width="16"
                               Height="16"/>
                    </Button>
                </Grid>

                <TextBlock Text="Подтвердите пароль"
                           Foreground="{StaticResource LightGray}"
                           Margin="0,0,0,2" FontSize="18"/>

                <!-- Подтверждение пароля -->
                <Grid>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                             FontSize="14"
                             Padding="8,4"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                    <TextBox x:Name="ConfirmPasswordTextBox"
                             FontSize="14"
                             Padding="8,4"
                             Visibility="Collapsed"/>
                    <Button
                            Style="{StaticResource EyeButtonStyle}"
                            HorizontalAlignment="Right"
                            Margin="0,-10,5,0"
                            Click="ToggleConfirmPassword_Click">
                        <Image Source="pack://application:,,,/Images/ic_showPassword.png"
                               Width="16"
                               Height="16"/>
                    </Button>
                </Grid>


                <Button Content="Отправить заявку"
                        Style="{StaticResource ModernButton}"
                        Margin="0,15,0,10"
                        Click="SendRequest_Click"/>

                <Button Content="Отмена"
                        Style="{StaticResource ModernButton}"
                        Click="Cancel_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>