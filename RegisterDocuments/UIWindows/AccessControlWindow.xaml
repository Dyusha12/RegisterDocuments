<Window x:Class="RegisterDocuments.AccessControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель управления доступом"
        WindowState="Maximized"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Column="0"
                Background="#F4F6F8"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,1,0"
                Padding="24">

            <Border.Resources>
                <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                    <Setter Property="Height" Value="38"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Style>

                <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="#555"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                </Style>

                <Style x:Key="InputStyle" TargetType="Control">
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="6"/>
                </Style>

            </Border.Resources>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,25">

                    <Grid Margin="0,0,0,10" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding UserName}"
                               FontSize="20"
                               TextWrapping="Wrap"
                               FontWeight="Bold"
                               Foreground="#212121"
                               VerticalAlignment="Center"
                               Grid.Column="0"/>

                        <Image Grid.Column="1" Width="28" Height="28" Source="pack://application:,,,/Images/ic_refresh.png" MouseLeftButtonDown="RefreshIcon_Click"/>
                    </Grid>
                    <TextBlock Text="{Binding UserRoleName}"
                               FontSize="14"
                               Foreground="#757575"
                               Margin="0,0,0,20"/>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Поиск" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="SearchTextBox" 
                             Style="{StaticResource InputStyle}"
                             TextChanged="SearchTextBox_TextChanged"/>
                    </StackPanel>

                    <Button Content="Отобразить активные записи"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ShowActive_Click"/>

                    <Button Content="Отобразить архивные записи"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ShowArchived_Click"/>

                    <Button x:Name="AddEmployeeButton" Content="Добавить сотрудника"
                        Style="{StaticResource PrimaryButtonStyle}" Click="AddEmployeeButton_Click"/>

                    <Button Content="Просмотреть историю изменений"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ViewHistoryButton_Click"/>
                    <Button Content="Просмотреть заявки на регистрацию"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ViewRegistrationListButton_Click"/>

                </StackPanel>

                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="10"
                        Padding="10">
                    <Border.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Background" Value="#F1F1F1"/>

                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="{TemplateBinding Background}">
                                            <Track x:Name="PART_Track"
                           IsDirectionReversed="True">

                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Opacity="0"/>
                                                </Track.DecreaseRepeatButton>

                                                <Track.Thumb>
                                                    <Thumb Margin="1" MinHeight="40" MinWidth="40">
                                                        <Thumb.Template>
                                                            <ControlTemplate>
                                                                <Border Background="#90AFCF"
                                            CornerRadius="4"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>

                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Opacity="0"/>
                                                </Track.IncreaseRepeatButton>

                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>

                                <Trigger Property="Orientation" Value="Vertical">
                                    <Setter Property="Width" Value="10"/>
                                </Trigger>

                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter Property="Height" Value="10"/>
                                </Trigger>

                            </Style.Triggers>

                        </Style>
                    </Border.Resources>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Редактирование данных"
                                FontSize="18"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,15"/>

                        <ScrollViewer Grid.Row="1"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled" >

                            <StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Логин" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SelectedEmployee.Login, Mode=TwoWay}"
                         Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SelectedEmployee.Password, Mode=TwoWay}"
                         Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Фамилия" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SelectedEmployee.LastName, Mode=TwoWay}"
                         Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Имя" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SelectedEmployee.FirstName, Mode=TwoWay}"
                         Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Отчество" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SelectedEmployee.MiddleName, Mode=TwoWay}"
                         Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Роль" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding RolesList}"
                          SelectedItem="{Binding SelectedEmployee.RoleName, Mode=TwoWay}"
                          Style="{StaticResource InputStyle}"
                          PreviewMouseWheel="ComboBox_PreviewMouseWheel"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Архивная запись?"
                           Style="{StaticResource FieldLabelStyle}"/>
                                    <CheckBox x:Name="ArchivedCheckBox"
                          Content="Поместить в архив"
                          IsChecked="{Binding SelectedEmployee.Archived, Mode=TwoWay}"/>
                                </StackPanel>

                            </StackPanel>

                        </ScrollViewer>

                        <Button Grid.Row="2"
                            Content="Сохранить изменения"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,15,0,0"
                            Click="SaveButton_Click"/>

                    </Grid>

                </Border>

                <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,25,0,0">
                    <Button Content="Вернуться назад"
                            Width="180"
                            Style="{StaticResource DangerButtonStyle}" 
                            Click="ExitButton_Click"/>
                </StackPanel>

            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Background" Value="#F1F1F1"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track">

                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Opacity="0"/>
                                        </Track.DecreaseRepeatButton>

                                        <Track.Thumb>
                                            <Thumb Margin="1" MinHeight="40" MinWidth="40">
                                                <Thumb.Template>
                                                    <ControlTemplate>
                                                        <Border Background="#90AFCF"
                                            CornerRadius="4"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>

                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Opacity="0"/>
                                        </Track.IncreaseRepeatButton>

                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <Style.Triggers>

                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter Property="Width" Value="10"/>
                        </Trigger>

                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Height" Value="10"/>
                        </Trigger>

                    </Style.Triggers>

                </Style>
            </Grid.Resources>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel Grid.IsSharedSizeScope="True" Margin="0">

                    <Grid Grid.IsSharedSizeScope="True" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition SharedSizeGroup="col0" Width="125"/>
                            <ColumnDefinition SharedSizeGroup="col1" Width="150"/>
                            <ColumnDefinition SharedSizeGroup="col2" Width="130"/>
                            <ColumnDefinition SharedSizeGroup="col3" Width="180"/>
                            <ColumnDefinition SharedSizeGroup="col4" Width="180"/>
                            <ColumnDefinition SharedSizeGroup="col5" Width="180"/>
                            <ColumnDefinition SharedSizeGroup="col6" Width="150"/>
                            <ColumnDefinition SharedSizeGroup="col7" Width="115"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="6" Height="40" Background="#D3EFFF" CornerRadius="4">
                            <TextBlock Text="Код сотрудника" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="6" Height="40" Background="#D3EFFF" CornerRadius="4">
                            <TextBlock Text="Логин" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="6" Height="40" Background="#D3EFFF" CornerRadius="4">
                            <TextBlock Text="Пароль" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="3" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="6" Height="40" Background="#D3EFFF" CornerRadius="4">
                            <TextBlock Text="Фамилия" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="4" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="6" Height="40" Background="#D3EFFF" CornerRadius="4">
                            <TextBlock Text="Имя" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="5" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="6" Height="40" Background="#D3EFFF" CornerRadius="4">
                            <TextBlock Text="Отчество" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="6" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="6" Height="40" Background="#D3EFFF" CornerRadius="4">
                            <TextBlock Text="Роль" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="7" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="6" Height="40" Background="#D3EFFF" CornerRadius="4">
                        <TextBlock Text="Архивный" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <ListBox x:Name="EmployeesListBox"
                     ItemsSource="{Binding Employees}"
                     BorderThickness="0"
                     Background="Transparent"
                     SelectionMode="Single"
                     SelectionChanged="EmployeesListBox_SelectionChanged">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Top"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" BorderBrush="Gray" BorderThickness="0,0,0,1" Background="{TemplateBinding Background}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#ADD8E6"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#D3EFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="Gray" BorderThickness="0,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition SharedSizeGroup="col0" Width="125"/>
                                            <ColumnDefinition SharedSizeGroup="col1" Width="150"/>
                                            <ColumnDefinition SharedSizeGroup="col2" Width="130"/>
                                            <ColumnDefinition SharedSizeGroup="col3" Width="180"/>
                                            <ColumnDefinition SharedSizeGroup="col4" Width="180"/>
                                            <ColumnDefinition SharedSizeGroup="col5" Width="180"/>
                                            <ColumnDefinition SharedSizeGroup="col6" Width="150"/>
                                            <ColumnDefinition SharedSizeGroup="col7" Width="115"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="4">
                                            <TextBlock Text="{Binding Code}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="4">
                                            <TextBlock Text="{Binding Login}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="4">
                                            <TextBlock Text="******" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="3" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="4">
                                            <TextBlock Text="{Binding LastName}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="4" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="4">
                                            <TextBlock Text="{Binding FirstName}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="5" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="4">
                                            <TextBlock Text="{Binding MiddleName}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="6" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="4">
                                            <TextBlock Text="{Binding RoleName}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="7" BorderBrush="Gray" BorderThickness="0,0,0,0" Padding="4">
                                            <CheckBox IsChecked="{Binding Archived}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>