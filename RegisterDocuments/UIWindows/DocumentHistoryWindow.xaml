<Window x:Class="RegisterDocuments.DocumentHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История изменений документа"
        Background="#F4F6F8"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Width="480"
        Height="450">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
    </Window.Resources>

    <Border Padding="24" Background="#F4F6F8" CornerRadius="10">
        <StackPanel Width="400">
            <TextBlock Text="История изменений документа" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Код документа" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox x:Name="DocumentCodeTextBox" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Content="Отмена" Grid.Column="0" Style="{StaticResource PrimaryButtonStyle}" Click="Cancel_Click"/>
                <Button Content="Поиск" Grid.Column="2" Style="{StaticResource PrimaryButtonStyle}" Click="Search_Click"/>
            </Grid>

            <DataGrid x:Name="HistoryDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      Height="200"
                      Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Кто изменил" Binding="{Binding EmployeeCode}" Width="*"/>
                    <DataGridTextColumn Header="Дата изменения" Binding="{Binding ChangeDate}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Border>
</Window>