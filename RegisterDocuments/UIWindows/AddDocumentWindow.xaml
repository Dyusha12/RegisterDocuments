<Window x:Class="RegisterDocuments.AddDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить документ"
        Background="#F4F6F8"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
    </Window.Resources>

    <Border Padding="24" Background="#F4F6F8" CornerRadius="10">
        <StackPanel Width="300">
            <TextBlock Text="Добавление документа" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Название документа" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox x:Name="DocumentNameTextBox" Style="{StaticResource InputStyle}" Margin="0,0,0,10" TextWrapping="Wrap"
                AcceptsReturn="True" MinHeight="60"/>

            <TextBlock Text="Тип документа" Style="{StaticResource FieldLabelStyle}"/>
            <ComboBox x:Name="DocumentTypeComboBox" Style="{StaticResource InputStyle}" Margin="0,0,0,10" DisplayMemberPath="NameType" SelectedValuePath="CodeTypeDocument" PreviewMouseWheel="DocumentTypeComboBox_PreviewMouseWheel"/>

            <TextBlock Text="Статус документа" Style="{StaticResource FieldLabelStyle}"/>
            <ComboBox x:Name="StatusComboBox" Style="{StaticResource InputStyle}" Margin="0,0,0,10" DisplayMemberPath="NameStatus" SelectedValuePath="CodeStatus" PreviewMouseWheel="StatusComboBox_PreviewMouseWheel"/>

            <Grid Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Content="Отмена"
                        Grid.Column="0"
                        Width="80"
                        Height="38"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Center"
                        Click="Cancel_Click"/>

                <Button Content="Добавить"
                        Grid.Column="2"
                        Width="80"
                        Height="38"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Center"
                        Click="Add_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>