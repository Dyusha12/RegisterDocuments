<Window x:Class="RegisterDocuments.WorkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Документы"
        WindowState="Maximized"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
        Background="#F4F6F8"
        BorderBrush="#E0E0E0"
        BorderThickness="0,0,1,0"
        Padding="24">

            <Border.Resources>

                <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                    <Setter Property="Height" Value="38"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="LightGray"/>
                                        <Setter Property="Foreground" Value="DarkGray"/>
                                        <Setter Property="Cursor" Value="Arrow"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#1976D2"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                    <Setter Property="Background" Value="#D32F2F"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="LightGray"/>
                                        <Setter Property="Foreground" Value="DarkGray"/>
                                        <Setter Property="Cursor" Value="Arrow"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#D32F2F"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="#555"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                </Style>

                <Style x:Key="InputStyle" TargetType="Control">
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="6"/>
                </Style>

                <Style TargetType="ScrollBar">
                    <Setter Property="Background" Value="#F1F1F1"/>
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Opacity="0"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Background="#B0C4DE"
                                                    Margin="1"
                                                    Height="40">
                                                <Thumb.Template>
                                                    <ControlTemplate>
                                                        <Border Background="#90AFCF"
                                                CornerRadius="4"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Opacity="0"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

            </Border.Resources>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,25">

                    <Grid Margin="0,0,0,10" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding UserName}"
                           FontSize="20"
                           TextWrapping="Wrap"
                           FontWeight="Bold"
                           Foreground="#212121"
                           VerticalAlignment="Center"
                           Grid.Column="0"/>

                        <Image Grid.Column="1" Width="28" Height="28" Source="pack://application:,,,/Images/ic_refresh.png" MouseLeftButtonDown="RefreshIcon_Click"/>
                    </Grid>

                    <TextBlock Text="{Binding UserRoleName}"
                       FontSize="14"
                       Foreground="#757575"
                       Margin="0,0,0,20"/>

                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Поиск" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="SearchTextBox" 
                            Style="{StaticResource InputStyle}"
                            TextChanged="SearchTextBox_TextChanged"/>
                    </StackPanel>

                    <StackPanel>

                        <Button x:Name="AddTypeDocumentButton"
                            Content="Добавить тип документа"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="AddTypeDocumentButton_Click"/>

                        <Button x:Name="AddStatusButton"
                            Content="Добавить статус документа"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="AddStatusButton_Click"/>

                        <Button x:Name="AddDocumentButton"
                            Content="Добавить документ"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="AddDocumentButton_Click"/>

                        <Button x:Name="ShowStatisticsButton"
                            Content="Просмотреть статистику документов"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ShowStatisticsButton_Click"/>
                        
                        <Button x:Name="AccessControlButton"
                            Content="Панель управления доступа"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="AccessControlButton_Click"/>

                        <Button x:Name="DeleteDocumentButton"
                            Content="Удалить документ"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="DeleteDocumentButton_Click"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="10"
                        Padding="10">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Редактирование данных"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">

                            <StackPanel>
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Код документа" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SelectedDocument.CodeDocument, Mode=TwoWay}"
                                             Style="{StaticResource InputStyle}"
                                             BorderBrush="#BDBDBD"
                                             IsReadOnly="True"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Наименование документа" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="DocumentNameTextBox"
                         Text="{Binding SelectedDocument.DocumentName, Mode=TwoWay}"
                         Style="{StaticResource InputStyle}"
                             BorderBrush="#BDBDBD"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="60"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Тип документа" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="DocumentTypeComboBox"
                                          ItemsSource="{Binding DocumentTypesList}"
                                          SelectedValue="{Binding SelectedDocument.TypeDocumentCode, Mode=TwoWay}"
                                          SelectedValuePath="TypeCode"
                                          DisplayMemberPath="TypeName"
                                          Style="{StaticResource InputStyle}"
                                          BorderBrush="#BDBDBD"
                                          PreviewMouseWheel="DocumentTypeComboBox_PreviewMouseWheel"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Калька отправлена?"
                                        Style="{StaticResource FieldLabelStyle}"/>
                                    <CheckBox x:Name="SendTracingPaperCheckBox"
                                          Content="Отправлена"
                                          IsChecked="{Binding SelectedDocument.IsSent, Mode=TwoWay}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Статус" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="StatusComboBox"
                                          ItemsSource="{Binding Statuses}"
                                          SelectedItem="{Binding SelectedDocument.StatusName, Mode=TwoWay}"
                                          Style="{StaticResource InputStyle}"
                                          BorderBrush="#BDBDBD"
                                          PreviewMouseWheel="StatusComboBox_PreviewMouseWheel"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Дата отправки письма"
                                          Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker x:Name="SendDatePicker"
                                          Height="38"
                                          SelectedDate="{Binding SelectedDocument.SendDate, Mode=TwoWay}"
                                          Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Дата согласования"
                                            Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker x:Name="ApprovalDatePicker"
                                            Height="38"
                                            SelectedDate="{Binding SelectedDocument.ApprovalDate, Mode=TwoWay}"
                                            Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Дата получения кальки"
                                            Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker x:Name="ReceiveDatePicker"
                                            Height="38"
                                            SelectedDate="{Binding SelectedDocument.ReceiveDate, Mode=TwoWay}"
                                            Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Путь к PDF письму"
                                            Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="PdfSentTextBox"
                                             Text="{Binding SelectedDocument.SentFileName, Mode=TwoWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource InputStyle}"
                                             BorderBrush="#BDBDBD"
                                             PreviewMouseLeftButtonDown="PdfSentTextBox_PreviewMouseLeftButtonDown">
                                        <TextBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Удалить" Click="PdfSentDelete_Click"/>
                                            </ContextMenu>
                                        </TextBox.ContextMenu>
                                    </TextBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Путь к PDF ответу"
                                            Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="PdfReceivedTextBox"
                                             Text="{Binding SelectedDocument.ReceivedFileName, Mode=TwoWay}"
                                             IsReadOnly="True"
                                             Style="{StaticResource InputStyle}"
                                             BorderBrush="#BDBDBD"
                                             PreviewMouseLeftButtonDown="PdfReceivedTextBox_PreviewMouseLeftButtonDown">
                                        <TextBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Удалить" Click="PdfReceivedDelete_Click"/>
                                            </ContextMenu>
                                        </TextBox.ContextMenu>
                                    </TextBox>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Примечание" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="DocumentNoteTextBox"
                                             Text="{Binding SelectedDocument.Note, Mode=TwoWay}"
                                             Style="{StaticResource InputStyle}"
                                             BorderBrush="#BDBDBD"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MinHeight="60"/>
                                </StackPanel>

                            </StackPanel>

                        </ScrollViewer>

                        <Button Grid.Row="2"
                                x:Name="SaveButton"
                                Content="Сохранить изменения"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0,15,0,0"
                                Click="SaveButton_Click"/>
                    </Grid>

                </Border>

                <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    Margin="0,25,0,0">

                    <Button Content="Выйти из системы"
                    Width="180"
                    Style="{StaticResource DangerButtonStyle}" Click="ExitButton_Click"/>

                </StackPanel>

            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Background" Value="#F1F1F1"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track"
                                           IsDirectionReversed="False"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch">

                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Opacity="0"/>
                                        </Track.DecreaseRepeatButton>

                                        <Track.Thumb>
                                            <Thumb Margin="1"
                                   MinHeight="40"
                                   MinWidth="40">
                                                <Thumb.Template>
                                                    <ControlTemplate>
                                                        <Border Background="#90AFCF"
                                                CornerRadius="4"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>

                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Opacity="0"/>
                                        </Track.IncreaseRepeatButton>

                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <Style.Triggers>

                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter Property="Width" Value="10"/>
                        </Trigger>

                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Height" Value="10"/>
                        </Trigger>

                    </Style.Triggers>
                </Style>

                <Style TargetType="TabControl">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid ClipToBounds="True">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <ScrollViewer Grid.Row="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          Background="Transparent">
                                        <TabPanel IsItemsHost="True"
                                          Background="Transparent"
                                          HorizontalAlignment="Left"/>
                                    </ScrollViewer>

                                    <Border Grid.Row="1"
                                    Background="White"
                                    CornerRadius="6"
                                    Padding="5"
                                    Margin="0,5,0,0"
                                    BorderBrush="Gray"
                                    BorderThickness="1">
                                        <ContentPresenter ContentSource="SelectedContent"/>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                
                

                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="Margin" Value="2,2,2,0"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Foreground" Value="DarkSlateGray"/>
                    <Setter Property="Background" Value="LightGray"/>
                    <Setter Property="BorderBrush" Value="Gray"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                CornerRadius="6,6,0,0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#4DA6FF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#3399FF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#A3D1FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <TabControl x:Name="TabControlDocuments"
                Margin="20"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsSynchronizedWithCurrentItem="True" >

                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding TypeName}" FontWeight="Bold" FontSize="14"/>
                    </DataTemplate>
                </TabControl.ItemTemplate>

                <TabControl.ContentTemplate>
                    <DataTemplate>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">

                            <StackPanel Grid.IsSharedSizeScope="True" Margin="0">

                                <Grid Grid.IsSharedSizeScope="True" Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition SharedSizeGroup="col0" Width="200"/>
                                        <ColumnDefinition SharedSizeGroup="col1" Width="130"/>
                                        <ColumnDefinition SharedSizeGroup="col2" Width="80"/>
                                        <ColumnDefinition SharedSizeGroup="col3" Width="145"/>
                                        <ColumnDefinition SharedSizeGroup="col4" Width="135"/>
                                        <ColumnDefinition SharedSizeGroup="col5" Width="155"/>
                                        <ColumnDefinition SharedSizeGroup="col6" Width="80"/>
                                        <ColumnDefinition SharedSizeGroup="col7" Width="80"/>
                                        <ColumnDefinition SharedSizeGroup="col8" Width="155"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4" Height="40" Background="#D3EFFF" CornerRadius="4">
                                        <TextBlock Text="Наименование" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4" Height="40" Background="#D3EFFF" CornerRadius="4">
                                        <TextBlock Text="Калька отправлена?" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4" Height="40" Background="#D3EFFF" CornerRadius="4">
                                        <TextBlock Text="Статус" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="3" BorderBrush="Gray" BorderThickness="0,0,1,1"
                                            Padding="4" Height="40" Background="#D3EFFF" CornerRadius="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Дата отправки письма"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>

                                            <Button Grid.Row="1"
                                                    HorizontalAlignment="Right"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Click="FilterBySendDate_Click">

                                                <Image Source="pack://application:,,,/Images/ic_filter.png"
                                                       Width="12"
                                                       Height="12"/>
                                            </Button>

                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="4" BorderBrush="Gray" BorderThickness="0,0,1,1"
                                                Padding="4" Height="40" Background="#D3EFFF" CornerRadius="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Дата согласования"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>

                                            <Button Grid.Row="1"
                                                    HorizontalAlignment="Right"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Фильтр"
                                                    Click="FilterByApprovalDate_Click">

                                                <Image Source="pack://application:,,,/Images/ic_filter.png"
                                                       Width="12"
                                                       Height="12"/>
                                            </Button>

                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="5" BorderBrush="Gray" BorderThickness="0,0,1,1"
                                                    Padding="4" Height="40" Background="#D3EFFF" CornerRadius="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Дата получения кальки"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>

                                            <Button Grid.Row="1"
                                                    HorizontalAlignment="Right"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Фильтр"
                                                    Click="FilterByReceiveDate_Click">

                                                <Image Source="pack://application:,,,/Images/ic_filter.png"
                                                   Width="12"
                                                   Height="12"/>
                                            </Button>

                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="6" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4" Height="40" Background="#D3EFFF" CornerRadius="4">
                                        <TextBlock Text="PDF письма" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="7" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4" Height="40" Background="#D3EFFF" CornerRadius="4">
                                        <TextBlock Text="PDF ответа" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="8" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="4" Height="40" Background="#D3EFFF" CornerRadius="4">
                                        <TextBlock Text="Примечание" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <ListBox x:Name="DocumentsListBoxInner"
                                         ItemsSource="{Binding Documents}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         SelectionMode="Single"
                                         Margin="0"
                                         SelectionChanged="DocumentsListBox_SelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition SharedSizeGroup="col0" Width="200"/>
                                                    <ColumnDefinition SharedSizeGroup="col1" Width="130"/>
                                                    <ColumnDefinition SharedSizeGroup="col2" Width="80"/>
                                                    <ColumnDefinition SharedSizeGroup="col3" Width="145"/>
                                                    <ColumnDefinition SharedSizeGroup="col4" Width="135"/>
                                                    <ColumnDefinition SharedSizeGroup="col5" Width="155"/>
                                                    <ColumnDefinition SharedSizeGroup="col6" Width="80"/>
                                                    <ColumnDefinition SharedSizeGroup="col7" Width="80"/>
                                                    <ColumnDefinition SharedSizeGroup="col8" Width="155"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4">
                                                    <TextBlock Text="{Binding DocumentName}" TextWrapping="Wrap"/>
                                                </Border>

                                                <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4">
                                                    <CheckBox IsChecked="{Binding IsSent}" IsEnabled="False" HorizontalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4">
                                                    <TextBlock Text="{Binding StatusName}" HorizontalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Column="3" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4">
                                                    <TextBlock Text="{Binding SendDate, StringFormat={}{0:dd-MM-yyyy}}" HorizontalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Column="4" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4">
                                                    <TextBlock Text="{Binding ApprovalDate, StringFormat={}{0:dd-MM-yyyy}}" HorizontalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Column="5" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4">
                                                    <TextBlock Text="{Binding ReceiveDate, StringFormat={}{0:dd-MM-yyyy}}" HorizontalAlignment="Center"/>
                                                </Border>

                                                <Border Grid.Column="6" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4">
                                                    <Image x:Name="PdfSentIcon" Width="28" Height="28" 
                                                            Source="{Binding SentFileIcon, Mode=OneWay}" HorizontalAlignment="Center" 
                                                            MouseLeftButtonDown="PdfSentIcon_Click"/>
                                                </Border>

                                                <Border Grid.Column="7" BorderBrush="Gray" BorderThickness="0,0,1,1" Padding="4">
                                                    <Image x:Name="PdfReceivedIcon" Width="28" Height="28" 
                                                            Source="{Binding ReceivedFileIcon, Mode=OneWay}" HorizontalAlignment="Center" 
                                                            MouseLeftButtonDown="PdfReceivedIcon_Click"/>
                                                </Border>

                                                <Border Grid.Column="8" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="4">
                                                    <TextBlock Text="{Binding Note}" TextWrapping="Wrap"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>

                                </ListBox>

                            </StackPanel>

                        </ScrollViewer>

                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>
    </Grid>
</Window>