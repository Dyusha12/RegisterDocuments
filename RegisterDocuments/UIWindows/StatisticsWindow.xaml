<Window x:Class="RegisterDocuments.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика по документам"
        ResizeMode="NoResize"
        Width="1000"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <!-- Основная сетка окна -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель управления -->
        <Border Grid.Column="0"
                Background="#F4F6F8"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,1,0"
                Padding="24">

            <Border.Resources>

                <!-- Стиль основной кнопки -->
                <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                    <Setter Property="Height" Value="38"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                    <Setter Property="Background" Value="#1976D2"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- Стиль подписей -->
                <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="#555"/>
                    <Setter Property="Margin" Value="0,0,0,4"/>
                </Style>

                <!-- Общий стиль для элементов ввода -->
                <Style x:Key="InputStyle" TargetType="Control">
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="6"/>
                </Style>
            </Border.Resources>

            <!-- Панель с элементами управления -->
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <Image Grid.Column="1"
                           Width="28" Height="28"
                           Source="pack://application:,,,/Images/ic_refresh.png"
                           Cursor="Hand"
                           ToolTip="Обновить списки"
                           MouseLeftButtonDown="RefreshIcon_Click"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>

                    <!-- Выбор типа диаграммы -->
                    <TextBlock Text="Выбор типа диаграммы" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,15">

                        <!-- Круговая диаграмма -->
                        <RadioButton x:Name="PieChartRadioButton" GroupName="ChartType" Content="Круговая диаграмма" Margin="0,0,0,5" Checked="ChartTypeRadioButton_Checked"/>

                        <!-- Гистограмма -->
                        <RadioButton x:Name="BarChartRadioButton" GroupName="ChartType" Content="Гистограмма" Checked="ChartTypeRadioButton_Checked"/>
                    </StackPanel>

                    <!-- Выбор фильтра -->
                    <TextBlock Text="Фильтр для диаграммы" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,2"/>
                    <StackPanel Margin="0,0,0,10">

                        <!-- Фильтр по типу -->
                        <RadioButton x:Name="FilterByTypeRadioButton" GroupName="FilterType" Content="По типу документа" Margin="0,0,0,5" Checked="FilterTypeRadioButton_Checked"/>

                        <!-- Фильтр по статусу -->
                        <RadioButton x:Name="FilterByStatusRadioButton" GroupName="FilterType" Content="По статусу документа" Checked="FilterTypeRadioButton_Checked"/>
                    </StackPanel>

                    <!-- Выбор типа документа -->
                    <TextBlock Text="Тип документа" Style="{StaticResource FieldLabelStyle}" Margin="0,5,0,2"/>
                    <ComboBox x:Name="DocumentTypeComboBox"
                              ItemsSource="{Binding DocumentTypesList, Mode=TwoWay}"
                              SelectedValuePath="TypeCode"
                              DisplayMemberPath="TypeName"
                              Style="{StaticResource InputStyle}"
                              BorderBrush="#BDBDBD"
                              SelectionChanged="DocumentTypeComboBox_SelectionChanged" PreviewMouseWheel="DocumentTypeComboBox_PreviewMouseWheel"/>

                    <!-- Выбор статуса документа -->
                    <TextBlock Text="Статус документа" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,2"/>
                    <ComboBox x:Name="StatusComboBox"
                              ItemsSource="{Binding Statuses, Mode=TwoWay}"
                              Style="{StaticResource InputStyle}"
                              BorderBrush="#BDBDBD"
                              SelectionChanged="StatusComboBox_SelectionChanged" PreviewMouseWheel="StatusComboBox_PreviewMouseWheel"/>

                    <!-- Кнопки действий -->
                    <Button Content="Показать всю статистику" Style="{StaticResource PrimaryButtonStyle}" Click="ShowAllButton_Click" Margin="0,15,0,0"/>
                    <Button Content="Экспорт в Excel" Style="{StaticResource PrimaryButtonStyle}" Margin="0,10,0,0" Click="ExportExcel_Click"/>
                    <Button Content="Вернуться назад" Style="{StaticResource PrimaryButtonStyle}" Background="#D32F2F" Margin="0,70,0,0" Click="ExitButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Правая часть - отображение диаграммы -->
        <Border Grid.Column="1" Background="White" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок диаграммы -->
                <TextBlock Text="{Binding ChartTitle, Mode=OneWay}" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Margin="0,0,0,20"
                           TextAlignment="Center"/>

                <!-- Контейнер для визуализации диаграммы -->
                <Border Grid.Row="1" Background="#F4F6F8" CornerRadius="10" Padding="10">
                    <ContentControl x:Name="VisualChartContainer"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>